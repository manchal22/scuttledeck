{
  "name": "scuttledeck",
  "private": true,
  "version": "0.0.1",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter @scuttledeck/ingest test:integration",
    "db:generate": "pnpm --filter @scuttledeck/db generate",
    "db:migrate": "pnpm --filter @scuttledeck/db migrate",
    "dev:ingest": "pnpm --filter @scuttledeck/ingest dev",
    "e2e": "bash scripts/e2e.sh"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7.3"
  }
}
