{
  "name": "scuttledeck",
  "private": true,
  "version": "0.0.1",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "go test ./...",
    "e2e": "bash scripts/e2e.sh",
    "dev:ingest": "go run ./cmd/ingest",
    "dev:web": "pnpm --filter @scuttledeck/web dev",
    "seed": "go run ./cmd/seed"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7.3"
  }
}
