# Postgres connection string (docker-compose provides this for the ingest container)
DATABASE_URL=postgres://scuttledeck:scuttledeck@localhost:5432/scuttledeck

# GitHub App webhook secret — HMAC of every delivery is verified against this
GITHUB_WEBHOOK_SECRET=change-me

# Bootstrap ingest token for the default installation. The raw token is what
# CI runners send as `Authorization: Bearer …`; only its SHA-256 hash is stored.
INGEST_TOKEN=change-me-too

# GitHub org this installation watches (used by the bootstrap installation row)
GITHUB_ORG=your-org

# Port for the ingest service
PORT=8787
