FROM golang:1.26-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /out/ingest ./cmd/ingest && \
    CGO_ENABLED=0 go build -ldflags="-s -w" -o /out/seed ./cmd/seed

FROM alpine:3.20

RUN adduser -D -u 10001 scuttledeck
USER scuttledeck
COPY --from=build /out/ingest /usr/local/bin/ingest
COPY --from=build /out/seed /usr/local/bin/seed

EXPOSE 8787
ENTRYPOINT ["/usr/local/bin/ingest"]
